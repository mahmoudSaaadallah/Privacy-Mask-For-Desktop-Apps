<Window x:Class="PrivacyMask.App.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About PrivacyMask"
        Width="760"
        Height="760"
        MinWidth="680"
        MinHeight="700"
        FontFamily="Segoe UI Variable Text"
        Background="#F2ECE3"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Border Padding="28"
                Background="#FCFAF6"
                BorderBrush="#E9E1D3"
                BorderThickness="1"
                CornerRadius="26">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="74" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="62"
                            Height="62"
                            Background="#1F6E6C"
                            CornerRadius="18">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#F7F3ED"
                                   Text="PM" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="18,0,0,0">
                        <TextBlock FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#17313D"
                                   Text="About" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#51656E"
                                   TextWrapping="Wrap"
                                   Text="A note from the developer behind PrivacyMask and the privacy principles this app is built on." />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Margin="0,0,0,18"
                                Padding="22"
                                Background="#17313D"
                                CornerRadius="22">
                            <StackPanel>
                                <TextBlock FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#F7F3ED"
                                           Text="Mahmoud Saadallah" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#D4E3E3"
                                           Text="Software Engineer" />
                                <TextBlock Margin="0,16,0,0"
                                           Foreground="#F7F3ED"
                                           TextWrapping="Wrap">
                                    Hi, I'm Mahmoud Saadallah, a software engineer focused on building secure and privacy-first applications.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,0,18"
                                Padding="22"
                                Background="#F7F1E7"
                                CornerRadius="22">
                            <StackPanel>
                                <TextBlock FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#17313D"
                                           Text="Why this app?" />
                                <TextBlock Margin="0,12,0,0"
                                           Foreground="#51656E"
                                           TextWrapping="Wrap">
                                    This app was created with a simple goal: give users full control over what remains visible on screen when WhatsApp Desktop and Telegram Desktop are open.
                                </TextBlock>
                                <TextBlock Margin="0,12,0,0"
                                           Foreground="#51656E"
                                           TextWrapping="Wrap">
                                    I built PrivacyMask to provide a clean and secure way to protect message content with local overlays, without compromising user privacy.
                                </TextBlock>
                                <TextBlock Margin="0,12,0,0"
                                           Foreground="#51656E"
                                           TextWrapping="Wrap">
                                    There is no tracking, no analytics, and no hidden data collection.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,0,18"
                                Padding="22"
                                Background="#EDF5F4"
                                CornerRadius="22">
                            <StackPanel>
                                <TextBlock FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#17313D"
                                           Text="Privacy Commitment" />
                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock Margin="0,0,0,8"
                                               Foreground="#51656E"
                                               Text="• No personal data is collected" />
                                    <TextBlock Margin="0,0,0,8"
                                               Foreground="#51656E"
                                               Text="• No third-party services are used" />
                                    <TextBlock Margin="0,0,0,8"
                                               Foreground="#51656E"
                                               Text="• No background tracking" />
                                    <TextBlock Foreground="#51656E"
                                               Text="• All data stays on your device" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Padding="22"
                                Background="#FFFFFF"
                                CornerRadius="22"
                                BorderBrush="#E9E1D3"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#17313D"
                                           Text="Contact" />

                                <TextBlock Margin="0,14,0,0"
                                           Foreground="#51656E">
                                    <Run Text="Email: " />
                                    <Hyperlink Click="EmailLink_Click">mahmoud.saadallah73@gmail.com</Hyperlink>
                                </TextBlock>

                                <TextBlock Margin="0,10,0,0"
                                           Foreground="#51656E">
                                    <Run Text="GitHub: " />
                                    <Hyperlink Click="GitHubLink_Click">github.com/mahmoudsaaadallah</Hyperlink>
                                </TextBlock>

                                <TextBlock Margin="0,10,0,0"
                                           Foreground="#51656E">
                                    <Run Text="LinkedIn: " />
                                    <Hyperlink Click="LinkedInLink_Click">linkedin.com/in/mahmoudsaaadallah</Hyperlink>
                                </TextBlock>

                                <TextBlock Margin="0,18,0,0"
                                           Foreground="#51656E"
                                           TextWrapping="Wrap">
                                    Thank you for using this application.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <DockPanel Grid.Row="2"
                           Margin="0,20,0,0">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#8A6A38"
                               Text="PrivacyMask is local-first by design." />
                    <Button Width="110"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"
                            Background="#1F6E6C"
                            BorderBrush="#1F6E6C"
                            Click="Close_Click"
                            Content="Close" />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
