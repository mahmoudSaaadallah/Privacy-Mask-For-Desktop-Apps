<Window x:Class="PrivacyMask.App.MainWindow"
        x:Name="SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:PrivacyMask.App.ViewModels"
        mc:Ignorable="d"
        Title="PrivacyMask"
        Width="1460"
        Height="920"
        MinWidth="1180"
        MinHeight="760"
        FontFamily="Segoe UI Variable Text"
        Background="#F2ECE3"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="24"
                Background="#17313D"
                CornerRadius="26">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Width="62"
                            Height="62"
                            Margin="0,0,0,18"
                            Background="#1F6E6C"
                            CornerRadius="18">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#F7F3ED"
                                   Text="PM" />
                    </Border>

                    <TextBlock FontSize="30"
                               FontWeight="Bold"
                               Foreground="#F7F3ED"
                               Text="PrivacyMask" />
                    <TextBlock Margin="0,8,0,20"
                               TextWrapping="Wrap"
                               Foreground="#D4E3E3"
                               Text="A local-only privacy companion for WhatsApp Desktop and Telegram Desktop." />

                    <Border Margin="0,0,0,18"
                            Padding="18"
                            Background="#F8F4ED"
                            CornerRadius="20">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="General" />
                            <TextBlock Margin="0,6,0,18"
                                       Foreground="#51656E"
                                       Text="Keep the utility lightweight and predictable." />

                            <CheckBox Content="Launch when I sign in"
                                      IsChecked="{Binding LaunchAtLogin, Mode=TwoWay}" />
                            <CheckBox Content="Start minimized to tray"
                                      IsChecked="{Binding StartMinimized, Mode=TwoWay}" />

                            <Border Margin="0,8,0,0"
                                    Padding="12"
                                    Background="#ECE4D6"
                                    CornerRadius="16">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Current mode" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#51656E"
                                               Text="{Binding CurrentModeSummary}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,0,18"
                            Padding="18"
                            Background="#F8F4ED"
                            CornerRadius="20">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Hotkeys" />
                            <TextBlock Margin="0,6,0,14"
                                       Foreground="#51656E"
                                       Text="V1 ships with opinionated defaults. You can turn each one on or off here." />

                            <ItemsControl ItemsSource="{Binding Hotkeys}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:HotkeyBindingViewModel}">
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                Background="White"
                                                CornerRadius="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding DisplayName}" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Foreground="#51656E"
                                                               Text="{Binding GestureText}" />
                                                </StackPanel>
                                                <CheckBox Grid.Column="1"
                                                          VerticalAlignment="Center"
                                                          Content="Enabled"
                                                          IsChecked="{Binding Enabled, Mode=TwoWay}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Padding="18"
                            Background="#F8F4ED"
                            CornerRadius="20">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Capture note" />
                            <TextBlock Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="#51656E"
                                       Text="The overlay is strongest for local privacy and best-effort full-screen sharing. Window-only capture of the target app may bypass it." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="2"
                Padding="24"
                Background="#FCFAF6"
                CornerRadius="26">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,20">
                    <TextBlock FontSize="30"
                               FontWeight="Bold"
                               Text="App Profiles" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#51656E"
                               Text="Tune supported apps, choose a preset, and calibrate the zones with normalized values between 0 and 1." />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#8A6A38"
                               Text="{Binding ConfigPath}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding AppProfiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:AppProfileViewModel}">
                                <Border Margin="0,0,0,18"
                                        Padding="20"
                                        Background="White"
                                        CornerRadius="22"
                                        BorderBrush="#E9E1D3"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontSize="22"
                                                           FontWeight="Bold"
                                                           Text="{Binding DisplayName}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Foreground="#51656E"
                                                           Text="{Binding Summary}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      VerticalAlignment="Top"
                                                      Content="Enabled"
                                                      IsChecked="{Binding Enabled, Mode=TwoWay}" />
                                        </Grid>

                                        <Grid Margin="0,16,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Margin="0,0,16,0">
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="Activation mode" />
                                                <ComboBox Margin="0,8,0,0"
                                                          ItemsSource="{Binding ActivationModesSource, ElementName=SettingsWindow}"
                                                          SelectedItem="{Binding StartupMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Margin="0,0,16,0">
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="Preset" />
                                                <ComboBox Margin="0,8,0,0"
                                                          DisplayMemberPath="DisplayName"
                                                          ItemsSource="{Binding Presets}"
                                                          SelectedValue="{Binding SelectedPresetId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValuePath="PresetId" />
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                                    Width="132"
                                                    Margin="0,22,0,0"
                                                    Padding="14,10"
                                                    Background="#1F6E6C"
                                                    BorderBrush="#1F6E6C"
                                                    Click="ApplyPreset_Click"
                                                    Content="Apply preset"
                                                    Tag="{Binding}" />
                                        </Grid>

                                        <Border Margin="0,0,0,16"
                                                Padding="16"
                                                Background="#F7F1E7"
                                                CornerRadius="18">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Text="Mask darkness" />

                                                <Slider Grid.Column="1"
                                                        Margin="18,0,18,0"
                                                        Minimum="60"
                                                        Maximum="240"
                                                        TickFrequency="5"
                                                        IsSnapToTickEnabled="False"
                                                        ValueChanged="MaskIntensitySlider_ValueChanged"
                                                        Value="{Binding MaskIntensityPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                <TextBlock Grid.Column="2"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="#8A6A38"
                                                           Text="{Binding MaskIntensitySummary}" />

                                                <TextBlock Grid.Row="1"
                                                           Margin="0,18,0,0"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Text="Hover window (px)" />

                                                <StackPanel Grid.Row="1"
                                                            Grid.Column="1"
                                                            Margin="18,18,18,0"
                                                            Orientation="Horizontal">
                                                    <TextBlock VerticalAlignment="Center"
                                                               Foreground="#51656E"
                                                               Text="W" />
                                                    <TextBox Width="86"
                                                             Margin="8,0,14,0"
                                                             HorizontalContentAlignment="Center"
                                                             LostFocus="HoverRevealDimension_LostFocus"
                                                             PreviewTextInput="NumericTextBox_PreviewTextInput"
                                                             Text="{Binding HoverRevealWidthPixels, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                    <TextBlock VerticalAlignment="Center"
                                                               Foreground="#51656E"
                                                               Text="H" />
                                                    <TextBox Width="86"
                                                             Margin="8,0,0,0"
                                                             HorizontalContentAlignment="Center"
                                                             LostFocus="HoverRevealDimension_LostFocus"
                                                             PreviewTextInput="NumericTextBox_PreviewTextInput"
                                                             Text="{Binding HoverRevealHeightPixels, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                </StackPanel>

                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="2"
                                                           Margin="0,18,0,0"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="#8A6A38"
                                                           Text="{Binding HoverRevealSummary}" />
                                            </Grid>
                                        </Border>

                                        <DataGrid AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  HeadersVisibility="Column"
                                                  ItemsSource="{Binding Zones}"
                                                  RowBackground="#FCFAF6"
                                                  AlternatingRowBackground="#F7F1E7"
                                                  BorderThickness="0"
                                                  GridLinesVisibility="Horizontal"
                                                  MinHeight="260">
                                            <DataGrid.Columns>
                                                <DataGridCheckBoxColumn Binding="{Binding Enabled, Mode=TwoWay}" Header="On" Width="55" />
                                                <DataGridTextColumn Binding="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Zone" Width="170" />
                                                <DataGridTextColumn Binding="{Binding X, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Header="X" Width="70" />
                                                <DataGridTextColumn Binding="{Binding Y, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Header="Y" Width="70" />
                                                <DataGridTextColumn Binding="{Binding Width, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Header="W" Width="70" />
                                                <DataGridTextColumn Binding="{Binding Height, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Header="H" Width="70" />
                                                <DataGridTemplateColumn Header="Style" Width="130">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Style}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                        <DataTemplate>
                                                            <ComboBox ItemsSource="{Binding MaskStylesSource, ElementName=SettingsWindow}"
                                                                      SelectedItem="{Binding Style, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Binding="{Binding Strength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Header="Strength" Width="90" />
                                                <DataGridCheckBoxColumn Binding="{Binding RevealOnHover, Mode=TwoWay}" Header="Hover reveal" Width="110" />
                                                <DataGridCheckBoxColumn Binding="{Binding HideDuringTemporaryReveal, Mode=TwoWay}" Header="Hold reveal" Width="105" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <DockPanel Grid.Row="2"
                           Margin="0,18,0,0">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#51656E"
                               Text="Changes are local-only and saved as JSON under your user profile." />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right">
                        <Button Width="126"
                                Margin="0,0,12,0"
                                Background="#C3B6A2"
                                BorderBrush="#C3B6A2"
                                Click="CloseToTray_Click"
                                Content="Close to tray"
                                Foreground="#17313D" />
                        <Button Width="148"
                                Background="#CC7A21"
                                BorderBrush="#CC7A21"
                                Click="Save_Click"
                                Content="Save changes" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
